            UserInputService.InputChanged:Connect(function(input) if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then update(input) end end)
            UserInputService.InputEnded:Connect(function(input) if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then isDragging = false end end)
            local startP = math.clamp((default - min) / (max - min), 0, 1); Fill.Size = UDim2.new(startP, 0, 1, 0); Ball.Position = UDim2.new(startP, 0, 0.5, 0)
        end

        function ElementApi:AddButton(text, callback)
            local B = Instance.new("TextButton", TabPage); B.ZIndex = 4; B.Size = UDim2.new(1, -10, 0, 32); B.BackgroundColor3 = Color3.fromRGB(30, 30, 38); B.TextColor3 = Color3.fromRGB(255, 255, 255); B.Text = text; B.Font = "GothamBold"; B.TextSize = TextScale - 1; Instance.new("UICorner", B).CornerRadius = UDim.new(0, 6)
            B.MouseButton1Click:Connect(callback)
        end
        
        function ElementApi:AddLabel(text)
            local S = Instance.new("Frame", TabPage); S.ZIndex = 4; S.Size = UDim2.new(1, -10, 0, 25); S.BackgroundTransparency = 1
            local L = Instance.new("TextLabel", S); L.ZIndex = 5; L.Text = text:upper(); L.Size = UDim2.new(1, 0, 1, 0); L.TextColor3 = Color3.fromRGB(255, 255, 255); L.BackgroundTransparency = 1; L.Font = "GothamBold"; L.TextSize = TextScale - 2; L.TextXAlignment = "Left"
            local Line = Instance.new("Frame", S); Line.ZIndex = 5; Line.Size = UDim2.new(1, 0, 0, 1); Line.Position = UDim2.new(0, 0, 1, 0); Line.BackgroundColor3 = Color3.fromRGB(255, 255, 255); Line.BackgroundTransparency = 0.9
        end

        function ElementApi:AddKeybind(text, default, callback)
            local Key = default
            local Bound = false
            local K = Instance.new("Frame", TabPage); K.Size = UDim2.new(1, -10, 0, 30); K.BackgroundTransparency = 1; K.ZIndex = 4
            local L = Instance.new("TextLabel", K); L.ZIndex = 5; L.Text = text; L.Size = UDim2.new(1,0,1,0); L.TextColor3 = Color3.fromRGB(200,200,200); L.BackgroundTransparency = 1; L.TextXAlignment = "Left"; L.Font = "GothamBold"; L.TextSize = TextScale - 1
            local B = Instance.new("TextButton", K); B.ZIndex = 5; B.Size = UDim2.new(0, 60, 0, 22); B.Position = UDim2.new(1,-60,0.5,-11); B.BackgroundColor3 = Color3.fromRGB(40,40,50); B.Text = Key.Name; B.TextColor3 = Color3.fromRGB(255,255,255); B.Font = "GothamBold"; B.TextSize = TextScale - 2; Instance.new("UICorner", B).CornerRadius = UDim.new(0,4)
            
            B.MouseButton1Click:Connect(function()
                Bound = true
                B.Text = "..."
            end)
            
            UserInputService.InputBegan:Connect(function(input)
                if Bound and input.UserInputType == Enum.UserInputType.Keyboard then
                    Key = input.KeyCode
                    Bound = false
                    B.Text = Key.Name
                elseif not Bound and input.KeyCode == Key then
                    callback()
                end
            end)
        end

        return ElementApi
    end
    return TabApi
end

return Library
