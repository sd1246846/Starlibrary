-- OPTIMIZED SNOW SYSTEM (Single Loop)
local function CreateSnow(parent, count, zIndex)
    local container = Instance.new("Frame")
    container.Name = "SnowContainer"
    container.Size = UDim2.new(1, 0, 1, 0)
    container.BackgroundTransparency = 1
    container.ZIndex = zIndex or 1 
    container.Parent = parent

    local flakes = {}
    
    for i = 1, count do
        local flake = Instance.new("Frame")
        flake.Size = UDim2.new(0, 2, 0, 2)
        flake.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        flake.BackgroundTransparency = 0.6
        flake.BorderSizePixel = 0
        flake.ZIndex = zIndex or 1
        Instance.new("UICorner", flake).CornerRadius = UDim.new(1, 0)
        flake.Position = UDim2.new(math.random(), 0, math.random(), 0)
        flake.Parent = container
        
        table.insert(flakes, {
            Obj = flake,
            Speed = math.random(15, 30) / 100,
            Offset = i
        })
    end

    local conn
    conn = RunService.RenderStepped:Connect(function(dt)
        if not container or not container.Parent then 
            conn:Disconnect() 
            return 
        end
        
        local t = tick()
        for _, data in ipairs(flakes) do
            local flake = data.Obj
            local currentPos = flake.Position
            
            local newX = currentPos.X.Scale + math.sin(t + data.Offset) * 0.0004
            local newY = currentPos.Y.Scale + (data.Speed * dt)
            
            if newY > 1 then 
                newY = -0.05 
                newX = math.random()
            end
            
            flake.Position = UDim2.new(newX, 0, newY, 0)
        end
    end)
end

